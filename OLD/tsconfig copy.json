{
  "extends": "@rtorcato/js-tooling/typescript/react",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "lib": ["esnext", "dom"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": [
    "build.mjs",
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.spec.ts",
    "**/*.test.ts",
    "release.config.ts"
  ]
}
