{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/components/MyComponent.tsx",
    "src/components/theme-provider.tsx",
    "src/components/ui/*.tsx",
    "src/components/ui-extended/*.tsx",
    "src/hooks/index.ts",
    "src/hooks/*.{ts,tsx}",
    "src/lib/index.ts",
    "src/lib/*.ts",
    ".storybook/{main,preview}.ts",
    "src/**/*.stories.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/*.stories.{ts,tsx}",
    "!src/test/**",
    "!src/global.d.ts"
  ],
  "ignoreDependencies": ["tw-animate-css"],
  "ignoreWorkspaces": ["apps/docs"]
}
