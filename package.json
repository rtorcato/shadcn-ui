  "scripts": {
    "component-add": "pnpm dlx shadcn-ui add",
    "ui-add": "pnpm component-add && prettier src --write --list-different",
    "build:css": "postcss src/styles/globals.css -o dist/styles.css",
    "build": "rimraf ./dist && pnpm build:css && node build.mjs && tsc --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "version": "changeset",
    "release": "changeset version",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "prepack": "clean-package",
    "postpack": "clean-package restore",
    "package:check": "pnpm pack",
    "==================== Common ====================": "",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "clean": "rimraf .turbo node_modules dist",
    "================================================": ""
  },
