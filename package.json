	"scripts": {
		"dev": "storybook dev -p 6006",
		"component-add": "npx shadcn@latest add",
		"build:css": "postcss src/styles/globals.css -o dist/styles.css",
		"build-dev": "rimraf ./dist && pnpm build:css && cross-env NODE_ENV=development node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
		"build-prod": "rimraf ./dist && pnpm build:css && cross-env NODE_ENV=production node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
		"package:analyzer": "esbuild-analyzer meta.json",
		"package:analyzer1": "https://esbuild.github.io/analyze/",
		"bundle-size": "node scripts/check-bundle-size.mjs",
		"bundle-size:write": "node scripts/check-bundle-size.mjs --write",
		"==================== Common ====================": "",
		"lint": "pnpm exec biome lint .",
		"format": "pnpm exec biome format .",
		"check:fix": "pnpm exec biome check --fix",
		"check": "pnpm exec biome check .",
		"prepare": "husky",
		"typecheck": "tsc --noEmit",
		"doctor": "js-tooling doctor",
		"knip": "knip",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"coverage": "vitest run --coverage",
		"commit": "cz",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"================================================": ""
	},
