{
  "name": "@rtorcato/shadcn-ui",
  "version": "1.0.2",
  "type": "module",
  "author": "Richard Torcato",
  "description": "A React component package",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "react",
    "component",
    "typescript"
  ],
  "license": "ISC",
  "homepage": "https://gitlab.com/rtorcato/shadcn-ui",
  "packageManager": "pnpm@9.5.0",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/types/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/types/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/types/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "index": [
        "./dist/esm/index.d.ts",
        "./dist/components/*"
      ]
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "scripts": {
    "component-add": "pnpm dlx shadcn-ui add",
    "ui-add": "pnpm dlx shadcn-ui add && prettier src --write --list-different",
    "build:css": "postcss src/styles/globals.css -o dist/styles.css",
    "build:js": "rollup -c",
    "build": "node build.mjs && tsc --emitDeclarationOnly",
    "build0": "rimraf ./dist && pnpm build:css && pnpm build:js",
    "build1": "tsup",
    "prepublishOnly": "npm run build",
    "lint:fix": "turbo run lint:fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "version": "changeset",
    "release": "changeset version",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "prepack": "clean-package",
    "postpack": "clean-package restore",
    "package:check": "pnpm pack",
    "==================== Common ====================": "",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "clean": "rimraf .turbo node_modules dist",
    "================================================": ""
  },
  "dependencies": {
    "cmdk": "^1.0.0",
    "embla-carousel-react": "^8.1.8",
    "input-otp": "^1.2.4",
    "next-themes": "^0.3.0",
    "react-day-picker": "^9.0.7",
    "react-resizable-panels": "^2.0.22",
    "recharts": "^2.12.7",
    "sonner": "^1.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@jest/globals": "^29.7.0",
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@swc/core": "^1.7.6",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.14",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.5",
    "autoprefixer": "10.4.20",
    "changesets-gitlab": "^0.12.0",
    "class-variance-authority": "^0.7.0",
    "clean-package": "2.2.0",
    "clsx": "^2.1.1",
    "esbuild": "^0.23.0",
    "esbuild-node-externals": "^1.14.0",
    "jsdom": "^24.1.1",
    "postcss": "8.4.41",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "rimraf": "^6.0.1",
    "rollup": "^4.20.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-ts": "^3.4.5",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "3.4.8",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  },
  "peerDependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "lucide-react": "^0.424.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.52.2"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "publishConfig": {
    "@rtorcato:registry": "https://gitlab.com/api/v4/projects/60598964/packages/npm/"
  }
}
