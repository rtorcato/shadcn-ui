{
  "extends": "@rtorcato/js-tooling/typescript/react",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "lib": ["esnext", "dom"],
    "types": ["react", "react-dom", "tailwindcss"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["build.mjs", "node_modules", "dist", "build", "coverage", "**/*.spec.ts", "**/*.test.ts", "release.config.ts", "src/examples", "src/components/ui-stories"]
}
