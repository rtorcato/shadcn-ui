{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "extends": ["@rtorcato/js-tooling/biome"],
  "files": {
    "includes": [
      "!**/.pnpm-store",
      "!**/OLD",
      "!**/components/ui",
      "!**/.claude",
      "!**/styles/*.css",
      "!**/storybook-static"
    ]
  },
  "css": {
    "linter": {
      "enabled": false
    }
  }
}
